## ——— Voice Agent (legacy STT+LLM+TTS pipeline) ———
FF_VOICE_AGENT_ENABLED=false
VOICE_AGENT_TTS_VOICE=hi-IN-SwaraNeural
VOICE_AGENT_SESSION_TIMEOUT_MS=900000
VOICE_AGENT_MAX_TURNS=50
AZURE_OPENAI_CONVERSATION_DEPLOYMENT=

## ——— Realtime Concierge "Maya" (Azure OpenAI Realtime + WebRTC) ———
# Toggle the new free-form, mixed-initiative voice concierge. Default ON in dev,
# gated rollout in prod. Browser also reads NEXT_PUBLIC_FF_VOICE_REALTIME.
FF_VOICE_AGENT_REALTIME=true
# Optional override for a dedicated realtime resource. Use this when your
# chat/extract deployments live on one Azure OpenAI resource, but realtime
# lives on another (recommended for CribLiv).
AZURE_OPENAI_REALTIME_ENDPOINT=
# Optional but recommended when realtime uses a different Azure OpenAI
# resource than chat/extract. Falls back to AZURE_OPENAI_API_KEY if omitted.
AZURE_OPENAI_REALTIME_API_KEY=
# Required: the ACTUAL deployment name you created for your realtime model.
# Example current choices:
#   gpt-realtime-mini  (cheap; best for dev/staging)
#   gpt-realtime       (higher quality; best for prod)
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-realtime-mini
# Voice. One of alloy, ash, ballad, coral, echo, sage, shimmer, verse, marin.
# `sage` is warm and India-friendly; `coral` is brighter / more upbeat.
AZURE_OPENAI_REALTIME_VOICE=sage
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

## ——— WhatsApp Notifications (Meta Cloud API / WABA) ———
FF_WHATSAPP_NOTIFICATIONS=true
WHATSAPP_PROVIDER=mock
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_TOKEN=
WHATSAPP_API_URL=
